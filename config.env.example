# BTC实时通信系统配置模板
# 不要把真实 config.env 上传到 GitHub

# Binance U本位永续，只读即可
BINANCE_ENABLED=true
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SYMBOL=BTCUSDT

# OKX BTC 币本位永续，只读即可
OKX_ENABLED=true
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_INST_ID=BTC-USD-SWAP

# 刷新频率
# WebSocket实时更新内存；这里控制落库/界面刷新频率
PRICE_REFRESH_SECONDS=3
ACCOUNT_REFRESH_SECONDS=10
FUNDING_REFRESH_SECONDS=60

# 自动清理历史数据，默认保留30天
RETENTION_DAYS=30
