# BTC实时通信系统配置模板
# 不要把真实 config.env 上传到 GitHub
# API Key 只需要读取权限，不要开启交易/提现

BINANCE_ENABLED=true
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SYMBOL=BTCUSDT

OKX_ENABLED=true
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_INST_ID=BTC-USD-SWAP

# WebSocket实时更新内存；这里控制界面/落库/REST轮询频率
PRICE_REFRESH_SECONDS=3
ACCOUNT_REFRESH_SECONDS=10
FUNDING_REFRESH_SECONDS=60

# 自动清理历史数据，范围7-30天
RETENTION_DAYS=30
